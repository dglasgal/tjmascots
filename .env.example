# Copy to .env.local and fill in real values.
# Public Supabase (safe to expose — subject to Row Level Security rules)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Mapbox public token (for the production map tiles + geocoder)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Server-only keys (never exposed to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Contact email shown in the disclaimer / takedown footer
NEXT_PUBLIC_SITE_EMAIL=david@7ate9.com
